<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/yellow"
    tools:context=".Screen4Fragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <!-- Titre -->
        <TextView
            android:id="@+id/issueTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Titre de l'incident"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:background="#AA000000"
            android:padding="10dp"
            android:layout_marginBottom="8dp"/>

        <!-- Priorité + type -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp"
            android:gravity="center_vertical">

            <ImageView
                android:id="@+id/issuePriorityIcon"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_marginEnd="8dp"
                android:src="@drawable/ic_medium"/>

            <TextView
                android:id="@+id/issuePriority"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Priorité"
                android:textSize="16sp"
                android:textColor="@color/white"/>

            <TextView
                android:id="@+id/issueType"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Type"
                android:textSize="13sp"
                android:textColor="@color/white"
                android:background="#663d3d3d"
                android:padding="5dp"/>
        </LinearLayout>

        <!-- Description -->
        <TextView
            android:id="@+id/issueDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Description de l'incident"
            android:textSize="14sp"
            android:textColor="@color/white"
            android:background="#663d3d3d"
            android:padding="8dp"
            android:layout_marginBottom="8dp"/>

        <!-- Heure -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Heure : "
                android:textSize="14sp"
                android:textColor="#AAFFFFFF"/>

            <TextView
                android:id="@+id/issueTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--:--"
                android:textSize="14sp"
                android:textColor="@color/white"/>
        </LinearLayout>

        <!-- Statut -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Statut : "
                android:textSize="14sp"
                android:textColor="#AAFFFFFF"/>

            <RatingBar
                android:id="@+id/issueStatus"
                style="?android:attr/ratingBarStyleSmall"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:numStars="5"
                android:rating="0"
                android:isIndicator="true"/>
        </LinearLayout>

        <!-- Protocole -->
        <TextView
            android:id="@+id/issueProtocol"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Protocole"
            android:textSize="13sp"
            android:textColor="@color/white"
            android:background="#663d3d3d"
            android:padding="8dp"
            android:layout_marginBottom="16dp"/>

        <!-- ===== SECTION PHOTO ===== -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="PHOTO"
            android:textSize="12sp"
            android:textColor="#AAFFFFFF"
            android:textAllCaps="true"
            android:layout_marginBottom="4dp"/>

        <ImageView
            android:id="@+id/issuePhoto"
            android:layout_width="match_parent"
            android:layout_height="180dp"
            android:scaleType="centerCrop"
            android:background="#663d3d3d"
            android:layout_marginBottom="4dp"/>

        <Button
            android:id="@+id/btnPickPhoto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Choisir une photo"
            android:backgroundTint="#663d3d3d"
            android:textColor="@color/white"
            android:layout_marginBottom="16dp"
            app:cornerRadius="8dp"/>

        <!-- ===== SECTION POSITION ===== -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="POSITION MANUELLE"
            android:textSize="12sp"
            android:textColor="#AAFFFFFF"
            android:textAllCaps="true"
            android:layout_marginBottom="8dp"/>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tileLatitude"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Latitude"
            android:layout_marginBottom="8dp"
            app:boxStrokeColor="@color/white"
            app:hintTextColor="@color/white">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/latInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="numberDecimal|numberSigned"
                android:textColor="@color/white"/>
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tileLongitude"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Longitude"
            android:layout_marginBottom="8dp"
            app:boxStrokeColor="@color/white"
            app:hintTextColor="@color/white">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/lonInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="numberDecimal|numberSigned"
                android:textColor="@color/white"/>
        </com.google.android.material.textfield.TextInputLayout>

        <TextView
            android:id="@+id/positionStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#AAFFFFFF"
            android:textSize="12sp"
            android:gravity="center"
            android:layout_marginBottom="16dp"/>

        <Button
            android:id="@+id/btnViewMap"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Voir sur la carte"
            android:textSize="16sp"
            android:backgroundTint="@color/blue"
            android:textColor="@color/white"
            android:layout_marginBottom="8dp"
            app:cornerRadius="12dp"/>

    </LinearLayout>
</ScrollView>
