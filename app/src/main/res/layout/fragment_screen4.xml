<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/yellow"
    android:padding="12dp"
    tools:context=".Screen4Fragment">

    <!-- Titre -->
    <TextView
        android:id="@+id/issueTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Titre de l'incident"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="@color/white"
        android:background="#AA000000"
        android:padding="10dp"
        android:layout_marginBottom="8dp"/>

    <!-- Priorité + type -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="8dp"
        android:gravity="center_vertical">

        <ImageView
            android:id="@+id/issuePriorityIcon"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_marginEnd="8dp"
            android:src="@drawable/ic_medium"/>

        <TextView
            android:id="@+id/issuePriority"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Priorité"
            android:textSize="16sp"
            android:textColor="@color/white"/>

        <TextView
            android:id="@+id/issueType"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Type"
            android:textSize="13sp"
            android:textColor="@color/white"
            android:background="#663d3d3d"
            android:padding="5dp"/>
    </LinearLayout>

    <!-- Description -->
    <TextView
        android:id="@+id/issueDescription"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Description de l'incident"
        android:textSize="14sp"
        android:textColor="@color/white"
        android:background="#663d3d3d"
        android:padding="8dp"
        android:layout_marginBottom="8dp"/>

    <!-- Statut -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="8dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Statut : "
            android:textSize="14sp"
            android:textColor="#AAFFFFFF"/>

        <RatingBar
            android:id="@+id/issueStatus"
            style="?android:attr/ratingBarStyleSmall"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:numStars="5"
            android:rating="0"
            android:isIndicator="true"/>
    </LinearLayout>

    <!-- Protocole -->
    <TextView
        android:id="@+id/issueProtocol"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Protocole"
        android:textSize="13sp"
        android:textColor="@color/white"
        android:background="#663d3d3d"
        android:padding="8dp"
        android:layout_marginBottom="8dp"/>

    <!-- Placeholder image -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Photo"
        android:textSize="12sp"
        android:textColor="#AAFFFFFF"
        android:textAllCaps="true"
        android:layout_marginBottom="2dp"/>

    <FrameLayout
        android:id="@+id/imagePlaceholder"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#663d3d3d"
        android:layout_marginBottom="8dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="[ Image à venir ]"
            android:textColor="#88FFFFFF"
            android:textSize="13sp"/>
    </FrameLayout>

    <!-- Placeholder carte -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Carte"
        android:textSize="12sp"
        android:textColor="#AAFFFFFF"
        android:textAllCaps="true"
        android:layout_marginBottom="2dp"/>

    <FrameLayout
        android:id="@+id/mapPlaceholder"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#663d3d3d">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="[ Carte à venir ]"
            android:textColor="#88FFFFFF"
            android:textSize="13sp"/>
    </FrameLayout>

</LinearLayout>
